  "keyFeatures": [
    "Full-stack authentication with hosted login pages",
    "Enterprise SSO (SAML, OIDC) integration",
    "SCIM user provisioning and directory sync",
    "Agent authentication for AI applications",
    "MCP (Model Context Protocol) authentication",
    "Multi-language SDK support (Node.js, Python, Go, Java)",
    "Session management with configurable security policies",
    "Role-based access control (RBAC) and authorization",
    "Social login integrations",
    "Passwordless authentication (magic links, OTP, passkeys)",
    "Webhooks and event interceptors",
    "Self-service admin portal for enterprise customers",
    "Multi-app authentication support",
    "Custom domain and branding capabilities"
  ],
  "publicApiSurface": [
    "Authentication API - getAuthorizationUrl(), authenticateWithCode(), refreshAccessToken()",
    "Session Management - validateAccessToken(), getLogoutUrl()",
    "Organizations API - create, list, get, update, delete organizations",
    "Users API - create, list, get, update, delete users",
    "SSO Connections - configure SAML/OIDC providers",
    "SCIM API - user/group provisioning endpoints",
    "Directory Sync - manage enterprise user directories",
    "Roles & Permissions - RBAC management",
    "Webhooks - event subscriptions and handlers",
    "Admin Portal - embeddable SSO/SCIM setup widgets",
    "Agent Auth - OAuth flows for AI agents",
    "MCP Authentication - secure MCP server connections",
    "API Keys - machine-to-machine authentication",
    "Custom Attributes - extend user profiles",
    "Domain Management - custom authentication domains"
  ]
